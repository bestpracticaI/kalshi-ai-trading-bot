# Kalshi API Configuration
# Get your API key from: https://trading.kalshi.com/settings/api
KALSHI_API_KEY=your_kalshi_api_key_here

# Kalshi RSA private key for request signing — use ONE of the following:
#
# Option A — PEM file (default filename: kalshi_private_key.pem in project root)
# KALSHI_PRIVATE_KEY_PATH=C:\path\to\kalshi_private_key.pem
#
# Option B — Full PEM pasted in .env (use \n between lines, or real multiline in quoted block)
# KALSHI_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
#
# Option C — Base64 of the PEM file contents (single line; handy on Windows / CI)
# KALSHI_PRIVATE_KEY_BASE64=LS0tLS1CRUdJTi...

# OpenRouter API Configuration — ALL models (Claude Sonnet 4.5, GPT-5.4, Gemini 3.1 Pro, DeepSeek V3.2, Grok 4.1 Fast)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Trading Configuration
# Set to 'true' for live trading, 'false' for paper trading
LIVE_TRADING_ENABLED=false

# Logging Configuration
LOG_LEVEL=INFO
ENABLE_FILE_LOGGING=true
ENABLE_CONSOLE_LOGGING=true

# Database Configuration
DATABASE_URL=sqlite:///trading_system.db

# Performance Monitoring
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_LOG_INTERVAL_MINUTES=15
